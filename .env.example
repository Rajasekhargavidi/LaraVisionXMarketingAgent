OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4.1-mini

# Instagram Graph API credentials for publishing
INSTAGRAM_ACCESS_TOKEN=your_long_lived_ig_access_token_here
INSTAGRAM_IG_USER_ID=your_instagram_business_user_id_here
INSTAGRAM_IMAGE_URL=https://example.com/your-public-image.jpg

# WhatsApp Business Cloud API credentials
WHATSAPP_ACCESS_TOKEN=your_whatsapp_cloud_api_token_here
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here
WHATSAPP_RECIPIENT_NUMBER=recipient_phone_in_e164_format_here

